# ===================================================
#  ContaFácil — Configuração do Ambiente
#  Copie este arquivo para .env e preencha os valores
# ===================================================

# Porta do servidor (padrão: 3000)
PORT=3000

# Chave secreta para sessões (troque por algo aleatório longo)
SESSION_SECRET=troque_por_uma_chave_secreta_muito_longa_aqui_123

# -------------------------------------------------------
# Configuração de E-mail (SMTP)
# Para Gmail: ative "Senhas de app" em myaccount.google.com
# -------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app_aqui
EMAIL_FROM=ContaFácil <seu_email@gmail.com>

# E-mail padrão para receber alertas do escritório
EMAIL_ESCRITORIO=contabilidade@escritorio.com.br
